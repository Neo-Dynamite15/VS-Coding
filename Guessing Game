-- Description: This is a guessing game where the user has to guess a number between 1 and 100. 
-- The program will give feedback on whether the guess is too high, too low, or correct.

randomNumber = math.random(1, 100)
guess = 0
-- Set up attempts for the user to guess the number
attempts = 7

-- Welcome message and instructions for the user
print("Welcome to the Guessing Game!")
print("I have selected a random number between 1 and 100. Can you guess it?")

-- The user will have 7 attempts to guess the number. After each guess, the program will provide feedback and update the number of attempts left.
while attempts > 0 do
    print("You have " .. attempts .. " attempts left. Please enter your guess:")
    guess = tonumber(io.read())
    
    if guess == nil then -- Check if the input is a letter or not a number
        print("That's not a valid number. Please enter a number between 1 and 100.")
    elseif guess < randomNumber then
        print("Too low! Try again.") -- If the guess is too low, the program will prompt the user to try again.
        attempts = attempts - 1
    elseif guess > randomNumber then
        print("Too high! Try again.") -- If the guess is too high, the program will prompt the user to try again.
        attempts = attempts - 1
    else
        print("Congratulations! You've guessed the number!") --Victory message when the user guesses the correct number.
        break
    end
end
if attempts == 0 then -- If the user runs out of attempts, the program will reveal the correct number.
    print("You've run out of attempts. The number was " .. randomNumber .. ".")
end
